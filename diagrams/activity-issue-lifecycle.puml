@startuml
title Smart IMS - Activity Diagram (Issue Lifecycle + SLA)
skinparam shadowing false
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #222222
  FontColor #111111
}

start

partition "User / Reporter" {
  :Login;
  :Select Project;
  :Create Issue\n(title, description);
  note right
    Status = OPEN
    triaged=false for normal USER
  end note
}

partition "System" {
  :Persist Issue;
  :Log Timeline Activity (CREATED);
  :Send Notifications;
  :Write Audit Log;
}

partition "Manager/Admin" {
  if (Issue needs triage?) then (Yes)
    :Review Issue;
    :Update Severity / Priority;
    :Mark triaged=true;
  else (No)
  endif

  if (Assign engineer?) then (Manual)
    :Assign Engineer;
  else (Auto)
    :Auto-Assign\n(weighted load + active count);
  endif
}

partition "System" {
  :Log Timeline Activity (ASSIGNED/AUTO_ASSIGNED);
  :Notify Engineer;
  :Write Audit Log;
}

partition "Engineer" {
  :Start Work;
  :Update Status OPEN -> IN_PROGRESS;
}

partition "System" {
  :Initialize SLA Window\n(slaStartTime, slaDueTime);
  :Log Timeline Activity (STATUS_UPDATED);
}

partition "SLA Monitor (Scheduler)" {
  while (Issue not RESOLVED/CLOSED?) is (yes)
    :Evaluate SLA;
    if (AT_RISK or BREACHED?) then (Yes)
      partition "System" {
        :Set escalated=true (once);
        :If BREACHED: record SLA breach;
        :Notify stakeholders;
        :Write Audit Log (system);
      }
    else (No)
    endif
  endwhile (no)
}

partition "Engineer" {
  :Resolve Issue;
  :Update Status IN_PROGRESS -> RESOLVED;
}

partition "System" {
  :Set resolvedAt;
  :Log Timeline Activity (STATUS_UPDATED);
  :Notify Manager/Admin;
}

partition "Manager" {
  :Review Resolution;
  if (Accept?) then (Yes)
    :Update Status RESOLVED -> CLOSED;
  else (Reopen)
    :Update Status RESOLVED -> OPEN;
    note right
      Reopen clears SLA window\n(start/due) for next run.
    end note
  endif
}

partition "System" {
  :Log Timeline Activity;
  :Send Notifications;
  :Write Audit Log;
}

stop
@enduml
